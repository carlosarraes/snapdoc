{
  "name": "snapdoc-review",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build && vite build --config vite.annotator.config.ts && npm run stage:mermaid",
    "stage:mermaid": "node scripts/stage-mermaid.mjs",
    "test": "vitest run src",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "mermaid-11-15-0": "npm:mermaid@11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.0"
  }
}
